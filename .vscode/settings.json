{
    "java.compile.nullAnalysis.mode": "automatic",
    "java.configuration.updateBuildConfiguration": "automatic",
    "psi-header.config": {
        "forceToTop": true,
        "blankLinesAfter": 1,
        "author": "tutosrive",
        "authorEmail": "tutosriveorg@gmail.com",
        "license": "Custom",
        "year": "${date:YYYY}",
        "autoAdd": true
    },
    "psi-header.variables": [
        [
            "projectCreationYear",
            "2026"
        ],
        [
            "projectName",
            "javalin-with-mongodb-learn"
        ],
        [
            "projectURI",
            "https://github.com/tutosrive/javalin-with-mongodb-learn"
        ],
        [
            "projectDescription",
            "Just test-learn with javalin and in future with MongoDB"
        ],
        [
            "copyrightHolder",
            "tutosrive"
        ],
        [
            "licenseType",
            "GPL-3"
        ]
    ],
    "psi-header.templates": [
        {
            "language": "*",
            "template": [
                "<<projectName>> - <<projectDescription>>",
                "Copyright <<projectCreationYear>> - <<year>> <<copyrightHolder>>",
                "Licence: <<licenseType>>",
                "More information: <<projectURI>>/blob/main/LICENSE",
                "Author: <<author>> (<<authorEmail>>)",
                "",
                "File: <<fileRelativePath>>",
                "Created: <<filecreated('dddd, Do MMMM YYYY h:mm:ss a')>>",
                "-----",
                "Last Modified: <<dateformat('dddd, Do MMMM YYYY h:mm:ss a')>>",
                "Modified By: <<author>> (<<authorEmail>>)",
                "-----"
            ]
        }
    ],
    "psi-header.changes-tracking": {
        "isActive": true,
        "autoHeader": "autoSave",
        "modDateFormat": "dddd, Do MMMM YYYY h:mm:ss a",
        "modAuthor": "tutosrive",
        "enforceHeader": true,
        "exclude": [
            "json",
            "jsonc",
            "gitignore",
            "md",
            "txt",
            "sln",
            "csproj",
            "gradle",
            "bat"
        ],
        "excludeGlob": [
            "**/**.properties",
            "**/**.bat",
            "**/*.gradle",
            "**/*.yml",
            "**/.editorconfig",
            "**/*.md",
            "**/settings.json",
            "**/*.sln",
            "**/*.csproj",
            "**/.gitignore",
            "**/LICENSE",
            "**/README.md"
        ]
    }
}